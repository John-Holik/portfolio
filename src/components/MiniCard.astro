---
import type { MiniProject } from '../data/projects';

interface Props {
  project: MiniProject;
}

const { project } = Astro.props;
const Tag = project.href ? 'a' : 'div';
---

<Tag
  class="mini"
  href={project.href}
  target={project.href ? '_blank' : undefined}
  rel={project.href ? 'noopener' : undefined}
>
  <h4>{project.title} {project.href && <span class="arr">↗</span>}</h4>
  <p>{project.description}</p>
  <span class="mstack">{project.stack}</span>
</Tag>
